HOST=127.0.0.1
PORT=5177
WUQUAN_DB_FILE=/var/lib/wuquan/db.json
JWT_SECRET=replace-with-a-long-random-secret

# AI provider settings.
# If you use OpenAI-compatible APIs, keep the /v1/chat/completions endpoint.
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=replace-with-your-server-side-ai-key
AI_MODEL=gpt-4o-mini
AI_REQUIRE_AUTH=1
AI_TIMEOUT_MS=60000

# Set this to your production origin after HTTPS is ready.
CORS_ORIGIN=*
